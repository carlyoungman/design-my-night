{
  "name": "dmn-booking-plugin",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "start:admin": "vite build --watch --config vite.admin.config.ts",
    "start:frontend": "vite build --watch --config vite.frontend.config.ts",
    "watch:types": "tsc -w --noEmit",
    "start": "concurrently -c auto -n TYPES,ADMIN,FRONT \"npm:watch:types\" \"npm:start:admin\" \"npm:start:frontend\"",
    "build:admin": "vite build --config vite.admin.config.ts",
    "build:frontend": "vite build --config vite.frontend.config.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run build:admin && npm run build:frontend",
    "lint:ts": "eslint --ext .ts,.tsx,.js,.jsx src/admin src/frontend",
    "lint:scss": "stylelint \"src/{admin,frontend}/**/*.scss\"",
    "lint": "npm run lint:ts && npm run lint:scss",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,scss,css,md,json,yml,yaml}\""
  },
  "devDependencies": {
    "@base-ui-components/react": "^1.0.0-beta.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "@wordpress/eslint-plugin": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.3.5",
    "concurrently": "^9.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "prettier": "^3.3.3",
    "sass": "^1.77.0",
    "stylelint": "^16.7.0",
    "stylelint-config-recess-order": "^5.0.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "stylelint-scss": "^6.4.0",
    "stylelint-selector-bem-pattern": "^4.0.1",
    "typescript": "^5.5.4",
    "zod": "^4.1.11"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.2",
    "@mui/x-date-pickers": "^8.11.0",
    "@wordpress/api-fetch": "^7.31.0",
    "css-reset-and-normalize": "^2.3.6",
    "dayjs": "^1.11.18",
    "lucide": "^0.542.0",
    "lucide-react": "^0.544.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
