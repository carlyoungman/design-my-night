{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": [],
    "lib": ["ES2020", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/frontend/app/*"],
      "@api/*": ["src/frontend/api/*"],
      "@admin/*": ["src/admin/*"]
    }
  },
  "include": ["src/**/*"]
}
